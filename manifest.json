{
  "manifest_version": 3,
  "name": "Polymarket XTracker Pace Overlay Plus",
  "version": "0.2.1",
  "description": "在 Polymarket 推文计数市场页面标注当前推文数、区间所需时速/日均、以及预计触达时间。",
  "permissions": [],
  "host_permissions": [
    "https://polymarket.com/*",
    "https://xtracker.polymarket.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
